# Methodic Monday Brief — generator secrets (server-side only)
# Copy this to config/.env and fill in for LOCAL runs. config/.env is gitignored.
# In the cloud (GitHub Actions) these same names are set as repo Secrets instead;
# config.py reads them from the environment either way. Never commit real keys.

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Supabase ---
# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=https://your-project.supabase.co
# Service role key (secret). Safe here because the generator runs locally, server-side only.
# Never put this in the web app or the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service-role...

# --- Email (optional, off by default; see config.toml [email].enabled) ---
# Gmail address that sends the brief.
SMTP_USER=you@gmail.com
# Gmail App Password (NOT your normal password). Create at https://myaccount.google.com/apppasswords
SMTP_APP_PASSWORD=xxxxxxxxxxxxxxxx
# Where the brief gets sent.
EMAIL_TO=gavin@methodic.ventures
