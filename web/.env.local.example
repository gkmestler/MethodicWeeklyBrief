# Copy this file to web/.env.local (gitignored) and fill in real values from your
# Supabase project (Project Settings -> API). The app reads .env.local, not this file.

# Public — shipped to the browser. Safe to expose because RLS is on. Used for reads.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...anon...

# Server-only (NO NEXT_PUBLIC_ prefix). Used ONLY by the /api/trigger route handler
# to enqueue manual "Generate now" requests. Set this in Vercel project settings too.
# Never expose it to the browser. Omit it and the trigger button shows "not configured".
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service-role...

# Server-only. The "Generate now" button uses these to kick the GitHub Actions
# workflow that runs the generator (the cloud replacement for the Mac mini).
#   GITHUB_REPO            = "owner/repo" of the pushed project
#   GITHUB_DISPATCH_TOKEN  = a GitHub PAT with permission to dispatch workflows
#                            (fine-grained: Contents read/write; classic: 'repo')
# Set both in Vercel. Without them the button reports "GitHub trigger not configured".
GITHUB_REPO=your-username/MethodicWeeklyBrief
GITHUB_DISPATCH_TOKEN=github_pat_xxxxxxxx
